# 🔗 Link do Cardápio para Auto-Resposta
# Quando um cliente enviar uma mensagem pela primeira vez, o agent responderá com este link
CARDAPIO_LINK=https://ninja-restaurante.vercel.app/cardapio

# 🔗 Configurações do Supabase para consulta de pedidos
# Necessário para responder com status do pedido automaticamente
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_KEY=sua_chave_api_aqui

# 🤖 Chave API Gemini (opcional - para futuras funcionalidades de IA)
# GEMINI_API_KEY=sua_chave_aqui
